{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@mdigital_ui/ui": ["../mdigital_uikit/src/index.ts"],
      "@mdigital_ui/ui/*": ["../mdigital_uikit/src/components/*/index.ts"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
